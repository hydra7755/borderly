# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google Cloud Vision API Configuration
VITE_GOOGLE_CLOUD_VISION_ENABLED=false
VITE_GOOGLE_CLOUD_VISION_API_KEY=your_google_cloud_vision_api_key_here

# Stripe — publishable key (browser). Netlify: use VITE_STRIPE_PUBLIC_KEY or NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY
VITE_STRIPE_PUBLIC_KEY=pk_test_your_key_here
# STRIPE_SECRET_KEY=sk_test_...  (Netlify only — never commit)

# Gemini AI (Netlify Functions only — never expose in the browser)
# GEMINI_API_KEY=your_gemini_api_key_here
# Optional: GEMINI_MODEL=gemini-2.0-flash

VITE_API_BASE_URL=http://localhost:8765/api
VITE_CONTACT_EMAIL=contactborderly@gmail.com
