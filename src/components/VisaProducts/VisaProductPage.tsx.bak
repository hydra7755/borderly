import React, { useState, useEffect } from 'react';
import { useNavigate, useLocation } from 'react-router-dom';
import { motion, AnimatePresence } from 'framer-motion';
import { VisaProduct } from '../../types/visaProduct';
import { getVisaRequirement, getCountryNameFromCode } from '../../lib/api/visaRequirements';
import { ALL_COUNTRIES } from '../../utils/countries';
import { getUserCurrency } from '../../utils/geolocation';
import { 
  FaGlobe, 
  FaPassport, 
  FaCalendarAlt, 
  FaInfoCircle, 
  FaCreditCard, 
  FaFileAlt, 
  FaPlane, 
  FaCheckCircle, 
  FaQuestionCircle, 
  FaChevronDown, 
  FaChevronUp,
  FaMoneyBillWave,
  FaClock,
  FaCamera,
  FaHotel,
  FaShieldAlt,
  FaWpforms,
  FaClipboardCheck,
  FaFolderOpen,
  FaFile,
  FaRoute,
  FaUniversity
} from 'react-icons/fa';

// Mock Auth context if the real one doesn't exist
const useAuth = () => {
  return {
    user: {
      id: 'mock-user-id',
      email: 'user@example.com',
      nationality: null,
      profileComplete: false
    },
    loading: false,
    error: null
  };
};

interface VisaProductPageProps {
  product: VisaProduct;
}

const VisaProductPage: React.FC<VisaProductPageProps> = ({ product }) => {
  const navigate = useNavigate();
  const location = useLocation();
  const { user } = useAuth() || {}; 
  const [userNationality, setUserNationality] = useState<string | null>(null);
  const [userNationalityName, setUserNationalityName] = useState<string | null>(null);
  const [visaRequirementForUser, setVisaRequirementForUser] = useState<{
    requirement: string;
    canApply: boolean;
    stay_duration?: number;
    notes?: string;
  } | null>(null);
  const [loading, setLoading] = useState(false);
  const [userCurrency, setUserCurrency] = useState<string>('GBP');
  const [currencySymbol, setCurrencySymbol] = useState<string>('£');
  const [exchangeRates, setExchangeRates] = useState<{[key: string]: number}>({
    GBP: 1,
    USD: 1.31,
    EUR: 1.17,
    INR: 109.5,
    PKR: 365.8,
    JPY: 196.8,
    AUD: 1.95
  });
  const [selectedCurrency, setSelectedCurrency] = useState<string>('GBP');
  
  // Track which FAQ items are open
  const [openFaqItems, setOpenFaqItems] = useState<number[]>([]);
  
  // User subscription status (mock - would come from user profile)
  const [userSubscription, setUserSubscription] = useState<{
    status: 'none' | 'basic' | 'premium' | 'business';
    discountPercentage: number;
  }>({ status: 'none', discountPercentage: 0 });
  
  // Fixed service fee for all eVisa applications
  const SERVICE_FEE = 58.95; // in GBP - Fixed to avoid fluctuations

  useEffect(() => {
    const fetchUserData = async () => {
      try {
        setLoading(true);
        
        // Get user's currency based on their IP address
        const userCurrencyData = await getUserCurrency();
        setSelectedCurrency(userCurrencyData.code);
        setCurrencySymbol(userCurrencyData.symbol);
        
        // Get nationality from URL query parameter if available
        const queryParams = new URLSearchParams(location.search);
        const nationalityFromUrl = queryParams.get('nationality');
        
        let nationality = null;
        
        // If nationality is in URL, use it
        if (nationalityFromUrl) {
          nationality = nationalityFromUrl;
          console.log('Using nationality from URL:', nationality);
        } 
        // Otherwise try to get it from user profile
        else if (user) {
          try {
            const userProfile = await fetch(`/api/user/profile/${user.id}`).then(res => res.json());
            nationality = userProfile.nationality || null;
            console.log('Using nationality from user profile:', nationality);
            
            // Check for user subscription status
            if (userProfile.subscription) {
              // Set subscription status and discount percentage
              const subscriptionStatus = userProfile.subscription.status || 'none';
              let discountPercentage = 0;
              
              // Calculate discount based on subscription tier
              switch (subscriptionStatus) {
                case 'basic':
                  discountPercentage = 10; // 10% discount
                  break;
                case 'premium':
                  discountPercentage = 20; // 20% discount
                  break;
                case 'business':
                  discountPercentage = 30; // 30% discount
                  break;
                default:
                  discountPercentage = 0;
              }
              
              setUserSubscription({
                status: subscriptionStatus,
                discountPercentage
              });
            }
          } catch (error) {
            console.error('Error fetching user profile:', error);
            // Fallback to user.nationality if available
            nationality = user.nationality || null;
          }
        } else {
          // For demo purposes, randomly set a subscription for non-logged in users
          // In production, this would be removed
          const demoSubscriptions = ['none', 'basic', 'premium', 'business'];
          const randomSubscription = demoSubscriptions[Math.floor(Math.random() * demoSubscriptions.length)] as 'none' | 'basic' | 'premium' | 'business';
          
          let discountPercentage = 0;
          switch (randomSubscription) {
            case 'basic': discountPercentage = 10; break;
            case 'premium': discountPercentage = 20; break;
            case 'business': discountPercentage = 30; break;
            default: discountPercentage = 0;
          }
          
          setUserSubscription({
            status: randomSubscription,
            discountPercentage
          });
        }
        
        setUserNationality(nationality);
        
        // Set the full country name for display
        if (nationality) {
          const countryName = getCountryNameFromCode(nationality);
          setUserNationalityName(countryName);
          
          // Use the full country name for visa requirement lookup
          const visaReq = await getVisaRequirement(nationality, product.countryCode);
          
          if (visaReq) {
            const canApply = ['evisa', 'eta'].includes(visaReq.requirement);
            setVisaRequirementForUser({
              requirement: visaReq.requirement,
              canApply,
              stay_duration: visaReq.stay_duration,
              notes: visaReq.notes
            });
          }
        }
        
        // Try to detect user's location for currency
        try {
          const ipResponse = await fetch('https://ipapi.co/json/');
          const ipData = await ipResponse.json();
          if (ipData.currency) {
            setUserCurrency(ipData.currency);
            setSelectedCurrency(ipData.currency);
          }
        } catch (error) {
          console.error('Error detecting user location:', error);
          // Default to GBP if location detection fails
        }
        
      } catch (error) {
        console.error('Error fetching user data:', error);
      } finally {
        setLoading(false);
      }
    };
    
    fetchUserData();
  }, [user, product.countryCode, location.search]);

  const handleApplyClick = () => {
    if (!userNationality) {
      navigate('/login?redirect=' + encodeURIComponent(`/visa/${product.countryCode}`));
      return;
    }
    
    navigate(`/evisa/apply/${userNationality}/${product.countryCode}`);
  };

  // Toggle FAQ item open/closed state
  const toggleFaqItem = (index: number) => {
    setOpenFaqItems(prev => {
      if (prev.includes(index)) {
        return prev.filter(item => item !== index);
      } else {
        return [...prev, index];
      }
    });
  };

  const getButtonText = () => {
    if (!visaRequirementForUser) return 'Apply for Visa';
    
    switch (visaRequirementForUser.requirement) {
      case 'evisa':
        return 'Apply for eVisa';
      case 'eta':
        return 'Apply for ETA';
      case 'visa-on-arrival':
        return 'Get Visa on Arrival Info';
      case 'visa-free':
        return 'No Visa Required';
      case 'visa-required':
        return 'Apply for Visa';
      default:
        return 'Check Visa Options';
    }
  };

  const getButtonDisabled = () => {
    if (!visaRequirementForUser) return false;
    return visaRequirementForUser.requirement === 'visa-free' || 
           visaRequirementForUser.requirement === 'not-applicable';
  };

  const convertCurrency = (amountInGBP: number): number => {
    if (!amountInGBP) return 0;
    const rate = exchangeRates[selectedCurrency] || 1;
    return parseFloat((amountInGBP * rate).toFixed(2));
  };

  const getCurrencySymbol = (currency: string): string => {
    switch (currency) {
      case 'GBP': return '£';
      case 'USD': return '$';
      case 'EUR': return '€';
      case 'INR': return '₹';
      case 'PKR': return '₨';
      case 'JPY': return '¥';
      case 'AUD': return 'A$';
      default: return currency;
    }
  };

  const formatPrice = (amount: number): string => {
    return `${getCurrencySymbol(selectedCurrency)}${amount.toFixed(2)}`;
  };

  // Calculate eVisa application fee based on the country
  const getVisaApplicationFee = (): number => {
    // Fixed fee for each country to avoid fluctuations
    const fixedFees: {[key: string]: number} = {
      'USA': 61.57,
      'CAN': 61.57,
      'GBR': 61.57,
      'AUS': 61.57,
      'NZL': 61.57,
      'DEU': 61.57,
      'FRA': 61.57,
      'ITA': 61.57,
      'ESP': 61.57,
      'JPN': 61.57,
      'CHN': 61.57,
      'IND': 61.57,
      'BRA': 61.57,
      'ZAF': 61.57,
      'RUS': 61.57,
      'TUR': 61.57,
    };
    
    return fixedFees[product.countryCode] || 61.57; // Fixed fee for all countries
  };
  
  // Calculate service fee with subscription discount
  const getDiscountedServiceFee = (): number => {
    if (userSubscription.discountPercentage === 0) {
      return SERVICE_FEE;
    }
    
    const discountAmount = SERVICE_FEE * (userSubscription.discountPercentage / 100);
    return SERVICE_FEE - discountAmount;
  };
  
  // Get subscription name for display
  const getSubscriptionName = (): string => {
    switch (userSubscription.status) {
      case 'basic':
        return 'Basic';
      case 'premium':
        return 'Premium';
      case 'business':
        return 'Business';
      default:
        return 'None';
    }
  };
  
  // Get total price (application fee + discounted service fee)
  const getTotalPrice = (): number => {
    return getVisaApplicationFee() + getDiscountedServiceFee();
  };

  return (
    <div className="bg-gradient-to-b from-white to-gray-50 dark:from-gray-900 dark:to-gray-950 shadow-xl rounded-xl overflow-hidden max-w-7xl mx-auto">
      {/* Hero Section with Country Image */}
      <div className="relative h-80 bg-gray-200">
        {product.images && product.images.length > 0 ? (
          <img 
            src={product.images[0]} 
            alt={product.countryName} 
            className="w-full h-full object-cover"
          />
        ) : (
          <div className="w-full h-full flex items-center justify-center bg-gradient-to-r from-blue-500 to-indigo-600">
            <FaGlobe className="text-white text-6xl opacity-30" />
            <span className="text-white text-xl ml-4 font-medium">Explore {product.countryName}</span>
          </div>
        )}
        <div className="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"></div>
        <div className="absolute bottom-0 left-0 right-0 p-8">
          <div className="flex items-center space-x-3">
            <motion.h1 
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              transition={{ duration: 0.5 }}
              className="text-4xl font-bold text-white">
              {product.countryName} <span className="text-primary-400">Visa</span>
            </motion.h1>
          </div>
          <motion.div 
            initial={{ opacity: 0, y: 10 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.5, delay: 0.2 }}
            className="flex items-center mt-3">
            <span className={`px-4 py-1.5 text-sm font-medium rounded-full shadow-sm backdrop-blur-sm ${
              product.visaType === 'visa-free' ? 'bg-green-500/90 text-white' :
              product.visaType === 'evisa' ? 'bg-blue-500/90 text-white' :
              product.visaType === 'visa-on-arrival' ? 'bg-yellow-500/90 text-white' :
              product.visaType === 'eta' ? 'bg-purple-500/90 text-white' :
              'bg-red-500/90 text-white'
            }`}>
              {product.visaType === 'visa-free' ? 'Visa Free' :
               product.visaType === 'evisa' ? 'eVisa Available' :
               product.visaType === 'visa-on-arrival' ? 'Visa on Arrival' :
               product.visaType === 'eta' ? 'ETA Required' :
               'Visa Required'}
            </span>
          </motion.div>
        </div>
      </div>
      
      {/* Main Content */}
      <div className="p-8">
        {/* Currency Display */}
        <div className="mb-6 flex justify-end">
          <div className="relative">
            <div className="flex items-center space-x-2">
              <FaMoneyBillWave className="text-primary-500" />
              <span className="block text-sm font-medium text-gray-700 dark:text-gray-300">
                Showing prices in {selectedCurrency} {currencySymbol}
              </span>
            </div>
          </div>
        </div>

        {/* Visa Details and Pricing Cards - Side by Side */}
        <div className="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
          {/* Visa Requirement for User */}
          {userNationalityName && visaRequirementForUser && (
            <motion.div 
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              transition={{ duration: 0.5 }}
              className="rounded-xl overflow-hidden shadow-lg h-full"
            >
              {/* Header with gradient */}
              <div className={`p-6 text-white ${
                visaRequirementForUser.requirement === 'visa-free' ? 'bg-gradient-to-r from-green-600 to-green-700' :
                visaRequirementForUser.requirement === 'evisa' ? 'bg-gradient-to-r from-primary-600 to-primary-700' :
                visaRequirementForUser.requirement === 'visa-on-arrival' ? 'bg-gradient-to-r from-yellow-600 to-yellow-700' :
                visaRequirementForUser.requirement === 'eta' ? 'bg-gradient-to-r from-purple-600 to-purple-700' :
                visaRequirementForUser.requirement === 'not-applicable' ? 'bg-gradient-to-r from-gray-600 to-gray-700' :
                'bg-gradient-to-r from-red-600 to-red-700'
              }`}>
                <div className="flex items-center space-x-3">
                  <FaPassport className="text-white text-xl" />
                  <h3 className="text-xl font-bold text-white">Visa Details</h3>
                </div>
                
                <div className="mt-3 inline-block px-4 py-1.5 text-sm font-medium rounded-full bg-white/20 backdrop-blur-sm">
                  {visaRequirementForUser.requirement === 'visa-free' ? 'Visa Free Entry' :
                  visaRequirementForUser.requirement === 'evisa' ? 'eVisa Required' :
                  visaRequirementForUser.requirement === 'visa-on-arrival' ? 'Visa on Arrival' :
                  visaRequirementForUser.requirement === 'eta' ? 'ETA Required' :
                  visaRequirementForUser.requirement === 'not-applicable' ? 'Not Applicable' :
                  'Traditional Visa Required'}
                </div>
              </div>
              
              {/* Content */}
              <div className="p-6 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 h-full">
                <div className="space-y-4">
                  <div className="flex items-center">
                    <FaPassport className="mr-3 text-primary-500" />
                    <p className="text-gray-700 dark:text-gray-300">
                      <span className="font-medium">Nationality:</span> {userNationalityName}
                    </p>
                  </div>

                  <div className="flex items-center">
                    <FaGlobe className="mr-3 text-primary-500" />
                    <p className="text-gray-700 dark:text-gray-300">
                      <span className="font-medium">Destination:</span> {product.countryName}
                    </p>
                  </div>

                  {visaRequirementForUser.stay_duration && (
                    <div className="flex items-center">
                      <FaCalendarAlt className={`mr-3 ${
                        visaRequirementForUser.requirement === 'visa-free' ? 'text-green-500' :
                        visaRequirementForUser.requirement === 'evisa' ? 'text-primary-500' :
                        visaRequirementForUser.requirement === 'visa-on-arrival' ? 'text-yellow-500' :
                        visaRequirementForUser.requirement === 'eta' ? 'text-purple-500' :
                        'text-gray-500'
                      }`} />
                      <p className="text-gray-700 dark:text-gray-300">
                        <span className="font-medium">Maximum stay:</span> <span className="font-semibold">{visaRequirementForUser.stay_duration} days</span>
                      </p>
                    </div>
                  )}
                  
                  <div className="flex items-center">
                    <FaUniversity className="mr-3 text-primary-500" />
                    <p className="text-gray-700 dark:text-gray-300">
                      <span className="font-medium">Visa Type:</span> {product.visaType === 'visa-free' ? 'Visa Free' :
                      product.visaType === 'evisa' ? 'eVisa' :
                      product.visaType === 'visa-on-arrival' ? 'Visa on Arrival' :
                      product.visaType === 'eta' ? 'ETA' : 'Traditional Visa'}
                    </p>
                  </div>

                  <div className="flex items-center">
                    <FaRoute className="mr-3 text-primary-500" />
                    <p className="text-gray-700 dark:text-gray-300">
                      <span className="font-medium">Entry Type:</span> Single
                    </p>
                  </div>

                  <div className="flex items-center">
                    <FaClock className="mr-3 text-primary-500" />
                    <p className="text-gray-700 dark:text-gray-300">
                      <span className="font-medium">Validity:</span> 90 days from issue
                    </p>
                  </div>
                  
                  {visaRequirementForUser.notes && (
                    <div className="flex items-start mt-4 pt-4 border-t border-gray-200 dark:border-gray-700">
                      <FaInfoCircle className={`mr-3 mt-1 ${
                        visaRequirementForUser.requirement === 'visa-free' ? 'text-green-500' :
                        visaRequirementForUser.requirement === 'evisa' ? 'text-primary-500' :
                        visaRequirementForUser.requirement === 'visa-on-arrival' ? 'text-yellow-500' :
                        visaRequirementForUser.requirement === 'eta' ? 'text-purple-500' :
                        'text-gray-500'
                      }`} />
                      <p className="text-gray-700 dark:text-gray-300">{visaRequirementForUser.notes}</p>
                    </div>
                  )}
                </div>
              </div>
            </motion.div>
          )}

          {/* Pricing Section - Always visible */}
          <motion.div 
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.5, delay: 0.2 }}
            className="h-full"
          >
            <div className="flex items-center space-x-3 mb-6">
              <FaCreditCard className="text-primary-500 text-xl" />
              <h2 className="text-2xl font-bold text-primary-700 dark:text-primary-400">Visa Pricing</h2>
            </div>
            
            {/* Pricing Card */}
            <div className="bg-white dark:bg-gray-800 rounded-xl overflow-hidden shadow-xl border border-primary-200 dark:border-primary-700 transform hover:scale-[1.01] transition-transform duration-300">
              {/* Card Header */}
              <div className="bg-gradient-to-r from-primary-500 to-primary-700 p-6 text-white">
                <h3 className="text-lg font-bold mb-1">Visa Processing</h3>
                <div className="flex items-center space-x-2">
                  <FaShieldAlt className="text-primary-200" />
                  <p className="text-xl font-semibold">Guaranteed Fast Processing</p>
                </div>
              </div>
              
              {/* Card Body */}
              <div className="p-6">
                {/* Travelers */}
                <div className="flex justify-between items-center mb-6">
                  <div className="flex items-center">
                    <FaPassport className="text-primary-500 mr-2" />
                    <span className="text-gray-700 dark:text-gray-300 font-medium">Travelers</span>
                  </div>
                  <div className="flex items-center">
                    <button className="p-1 text-primary-500 hover:text-primary-600 focus:outline-none">
                      <span className="text-xl">-</span>
                    </button>
                    <span className="mx-3 text-gray-900 dark:text-white font-medium">1</span>
                    <button className="p-1 text-primary-500 hover:text-primary-600 focus:outline-none">
                      <span className="text-xl">+</span>
                    </button>
                  </div>
                </div>
                
                {/* Price - Fixed price without options */}
                <div className="mb-6">
                  <h4 className="text-primary-600 dark:text-primary-400 font-medium mb-3">Price</h4>
                  
                  <div className="flex items-center justify-between p-3 rounded-md bg-primary-50 dark:bg-primary-900/20 border border-primary-100 dark:border-primary-800">
                    <span className="text-gray-900 dark:text-white font-medium">Total Price</span>
                    <span className="font-bold text-primary-600 dark:text-primary-400">{formatPrice(convertCurrency(getTotalPrice()))}</span>
                  </div>
                </div>
                
                {/* Price Breakdown */}
                <div className="space-y-4 mb-6">
                  {/* Application Fee */}
                  <div className="flex justify-between items-center">
                    <div>
                      <h4 className="text-sm text-primary-600 dark:text-primary-400">Visa Application Fee</h4>
                    </div>
                    <div className="text-sm font-medium text-primary-700 dark:text-primary-300">
                      {formatPrice(convertCurrency(getVisaApplicationFee()))}
                    </div>
                  </div>
                  
                  {/* Service Fee */}
                  <div className="flex justify-between items-center">
                    <div>
                      <h4 className="text-sm text-primary-600 dark:text-primary-400">Visa Service Fee</h4>
                    </div>
                    <div>
                      {userSubscription.discountPercentage > 0 ? (
                        <div className="text-right">
                          <span className="text-xs line-through text-gray-500 mr-1">
                            {formatPrice(convertCurrency(SERVICE_FEE))}
                          </span>
                          <span className="text-sm font-medium text-primary-600 dark:text-primary-400">
                            {formatPrice(convertCurrency(getDiscountedServiceFee()))}
                          </span>
                        </div>
                      ) : (
                        <span className="text-sm font-medium text-primary-700 dark:text-primary-300">
                          {formatPrice(convertCurrency(SERVICE_FEE))}
                        </span>
                      )}
                    </div>
                  </div>
                  
                  {/* Subscription Discount */}
                  {userSubscription.discountPercentage > 0 && (
                    <div className="flex justify-between items-center">
                      <div>
                        <h4 className="text-sm text-primary-600 dark:text-primary-400 flex items-center">
                          <FaCheckCircle className="mr-1 text-primary-500" />
                          {getSubscriptionName()} Discount
                        </h4>
                      </div>
                      <div className="text-sm font-medium text-primary-600 dark:text-primary-400">
                        -{userSubscription.discountPercentage}%
                      </div>
                    </div>
                  )}
                </div>
                
                {/* Total Amount */}
                <div className="flex justify-between items-center border-t border-primary-200 dark:border-primary-800 pt-4 mt-4">
                  <h4 className="font-medium text-primary-700 dark:text-primary-300">Total Amount</h4>
                  <div className="text-2xl font-bold text-primary-600 dark:text-primary-400">
                    {formatPrice(convertCurrency(getTotalPrice()))}
                  </div>
                </div>
                
                {/* Apply Button */}
                <button 
                  onClick={handleApplyClick}
                  disabled={getButtonDisabled()}
                  className="w-full bg-gradient-to-r from-primary-500 to-primary-600 hover:from-primary-600 hover:to-primary-700 text-white font-medium py-3 px-4 rounded-md mt-6 transition-all shadow-md hover:shadow-lg disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:from-primary-500 disabled:hover:to-primary-600"
                >
                  {getButtonText()}
                </button>
              </div>
              
              {/* Upgrade Prompt */}
              {userSubscription.status === 'none' && (
                <div className="bg-primary-50 dark:bg-primary-900/20 p-4 border-t border-primary-100 dark:border-primary-800">
                  <p className="text-sm text-center text-primary-700 dark:text-primary-300">
                    <span className="font-medium">Upgrade to a subscription</span> and save up to 30% on service fees
                  </p>
                  <div className="mt-2 text-center">
                    <button 
                      onClick={() => navigate('/pricing')}
                      className="inline-flex items-center px-4 py-2 text-sm font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300"
                    >
                      View Plans
                      <svg className="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M9 5l7 7-7 7"></path>
                      </svg>
                    </button>
                  </div>
                </div>
              )}
            </div>
          </motion.div>
        )}

        {/* Visa Details */}
        <motion.div 
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ duration: 0.5, delay: 0.4 }}
          className="mb-8"
        >
          <div className="flex items-center space-x-3 mb-6">
            <FaFileAlt className="text-primary-500 text-xl" />
            <h2 className="text-2xl font-bold text-gray-900 dark:text-white">Visa Details</h2>
          </div>
          
          <div className="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
            <div className="border rounded-lg p-4 bg-white dark:bg-gray-800 shadow-sm">
              <h3 className="text-sm font-medium text-gray-500 mb-1">Visa Type</h3>
              <p className="font-medium">{product.visaType.replace(/-/g, ' ').replace(/\b\w/g, (l: string) => l.toUpperCase())}</p>
            </div>
            
            <div className="border rounded-lg p-4 bg-white dark:bg-gray-800 shadow-sm">
              <h3 className="text-sm font-medium text-gray-500 mb-1">Validity</h3>
              <p className="font-medium">{product.visaValidity}</p>
            </div>
            
            <div className="border rounded-lg p-4 bg-white dark:bg-gray-800 shadow-sm">
              <h3 className="text-sm font-medium text-gray-500 mb-1">Length of Stay</h3>
              <p className="font-medium">{product.lengthOfStay}</p>
            </div>
            
            <div className="border rounded-lg p-4 bg-white dark:bg-gray-800 shadow-sm">
              <h3 className="text-sm font-medium text-gray-500 mb-1">Entry Type</h3>
              <p className="font-medium">{product.entryType.replace(/-/g, ' ').replace(/\b\w/g, (l: string) => l.toUpperCase())}</p>
            </div>
            
            <div className="border rounded-lg p-4 bg-white dark:bg-gray-800 shadow-sm">
              <h3 className="text-sm font-medium text-gray-500 mb-1">Processing Time</h3>
              <p className="font-medium">Normal: {product.processingTime.normal}</p>
              {product.processingTime.express && (
                <p className="font-medium">Express: {product.processingTime.express}</p>
              )}
            </div>
          </div>
          
          {/* Requirements */}
          <div className="mb-6 bg-white dark:bg-gray-800 rounded-xl overflow-hidden shadow-md border border-gray-200 dark:border-gray-700">
            <div className="bg-gradient-to-r from-blue-600 to-blue-700 p-4 text-white">
              <h3 className="text-lg font-bold flex items-center">
                <FaClipboardCheck className="mr-2" /> Requirements
              </h3>
            </div>
            <div className="p-5">
              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                {product.requirements && product.requirements.map((req: string, index: number) => {
                  // Map requirement text to appropriate icon
                  let icon = <FaCheckCircle className="text-green-500" />;
                  
                  if (req.toLowerCase().includes('passport'))
                    icon = <FaPassport className="text-blue-500" />;
                  else if (req.toLowerCase().includes('photo'))
                    icon = <FaCamera className="text-blue-500" />;
                  else if (req.toLowerCase().includes('accommodation') || req.toLowerCase().includes('hotel'))
                    icon = <FaHotel className="text-blue-500" />;
                  else if (req.toLowerCase().includes('fund') || req.toLowerCase().includes('bank') || req.toLowerCase().includes('financial'))
                    icon = <FaMoneyBillWave className="text-blue-500" />;
                  else if (req.toLowerCase().includes('ticket') || req.toLowerCase().includes('flight'))
                    icon = <FaPlane className="text-blue-500" />;
                  else if (req.toLowerCase().includes('insurance'))
                    icon = <FaShieldAlt className="text-blue-500" />;
                  else if (req.toLowerCase().includes('application') || req.toLowerCase().includes('form'))
                    icon = <FaWpforms className="text-blue-500" />;
                  
                  return (
                    <motion.div 
                      key={index}
                      whileHover={{ scale: 1.02 }}
                      className="flex items-start p-3 bg-gray-50 dark:bg-gray-700/30 rounded-lg border border-gray-100 dark:border-gray-700"
                    >
                      <div className="mr-3 mt-1">{icon}</div>
                      <div className="text-gray-700 dark:text-gray-300">{req}</div>
                    </motion.div>
                  );
                })}
              </div>
            </div>
          </div>
          
          {/* Required Documents */}
          <div className="mb-4 bg-white dark:bg-gray-800 rounded-xl overflow-hidden shadow-md border border-gray-200 dark:border-gray-700">
            <div className="bg-gradient-to-r from-indigo-600 to-indigo-700 p-4 text-white">
              <h3 className="text-lg font-bold flex items-center">
                <FaFolderOpen className="mr-2" /> Required Documents
              </h3>
            </div>
            <div className="p-5">
              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                {product.documents && product.documents.map((doc: string, index: number) => {
                  // Map document text to appropriate icon
                  let icon = <FaFile className="text-indigo-500" />;
                  
                  if (doc.toLowerCase().includes('passport'))
                    icon = <FaPassport className="text-indigo-500" />;
                  else if (doc.toLowerCase().includes('photo'))
                    icon = <FaCamera className="text-indigo-500" />;
                  else if (doc.toLowerCase().includes('itinerary'))
                    icon = <FaRoute className="text-indigo-500" />;
                  else if (doc.toLowerCase().includes('hotel') || doc.toLowerCase().includes('reservation'))
                    icon = <FaHotel className="text-indigo-500" />;
                  else if (doc.toLowerCase().includes('bank') || doc.toLowerCase().includes('statement'))
                    icon = <FaUniversity className="text-indigo-500" />;
                  else if (doc.toLowerCase().includes('insurance'))
                    icon = <FaShieldAlt className="text-indigo-500" />;
                  
                  return (
                    <motion.div 
                      key={index}
                      whileHover={{ scale: 1.02 }}
                      className="flex items-start p-3 bg-gray-50 dark:bg-gray-700/30 rounded-lg border border-gray-100 dark:border-gray-700"
                    >
                      <div className="mr-3 mt-1">{icon}</div>
                      <div className="text-gray-700 dark:text-gray-300">{doc}</div>
                    </motion.div>
                  );
                })}
              </div>
            </div>
          </div>
        </motion.div>
        
        {/* FAQs */}
        <motion.div 
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ duration: 0.5, delay: 0.3 }}
          className="mb-8"
        >
          <div className="flex items-center space-x-3 mb-6">
            <FaQuestionCircle className="text-primary-500 text-xl" />
            <h2 className="text-2xl font-bold text-gray-900 dark:text-white">Frequently Asked Questions</h2>
          </div>
          
          <div className="space-y-4 bg-white dark:bg-gray-800 rounded-xl overflow-hidden shadow-md border border-gray-200 dark:border-gray-700">
            {product.faqs && product.faqs.map((faq, index) => (
              <div key={index} className="border-b border-gray-200 dark:border-gray-700 last:border-b-0">
                <button
                  onClick={() => toggleFaqItem(index)}
                  className="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors duration-150"
                >
                  <h3 className="text-lg font-medium text-gray-900 dark:text-white">{faq.question}</h3>
                  <div className="text-gray-500 transition-transform duration-200 transform">
                    {openFaqItems.includes(index) ? (
                      <FaChevronUp className="h-5 w-5" />
                    ) : (
                      <FaChevronDown className="h-5 w-5" />
                    )}
                  </div>
                </button>
                
                {openFaqItems.includes(index) && (
                  <motion.div 
                    initial={{ opacity: 0, height: 0 }}
                    animate={{ opacity: 1, height: 'auto' }}
                    exit={{ opacity: 0, height: 0 }}
                    transition={{ duration: 0.2 }}
                    className="px-6 pb-4"
                  >
                    <p className="text-gray-700 dark:text-gray-300">{faq.answer}</p>
                  </motion.div>
                )}
              </div>
            ))}
          </div>
        </motion.div>
        
        {/* CTA Button */}
        <div className="mt-8">
          <button
            onClick={handleApplyClick}
            disabled={getButtonDisabled()}
            className={`w-full py-3 px-4 rounded-lg font-medium text-white ${
              getButtonDisabled() 
                ? 'bg-gray-400 cursor-not-allowed' 
                : 'bg-primary-600 hover:bg-primary-700'
            }`}
          >
            {getButtonText()}
          </button>
          
          {!userNationality && (
            <p className="text-sm text-gray-500 mt-2 text-center">
              Please log in or select your nationality to check visa requirements
            </p>
          )}
        </div>
      </div>
    </div>
  );
};

export default VisaProductPage;
